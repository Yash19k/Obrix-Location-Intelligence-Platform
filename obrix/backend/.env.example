# Obrix Backend — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ── Django ─────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=your-secret-key-min-50-chars-use-django-get-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO

# ── Database — PostgreSQL 18 + PostGIS 3.6.2 ───────────────────────────────
# Local development: install PostgreSQL 18 + PostGIS 3.6.2 natively.
# Production:        use a managed PostgreSQL instance (e.g. Render, Supabase).
DB_NAME=obrix_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Production-only (leave blank in local dev) ─────────────────────────────
# SENTRY_DSN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
